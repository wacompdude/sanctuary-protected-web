# Supabase public configuration only — never put the service-role key here.
# Project settings > API: https://app.supabase.com/project/_/settings/api
#
# IMPORTANT: Use the Project URL only — do NOT include /rest/v1
# Correct:   https://your-project-ref.supabase.co
# Incorrect: https://your-project-ref.supabase.co/rest/v1
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Prefer the legacy JWT anon key with @supabase/ssr:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Or the publishable key (also supported):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Canonical production URL (no trailing slash). Required in Vercel production so
# auth confirmation / invitation links never point at localhost.
# Also set Supabase Dashboard → Authentication → URL Configuration:
#   Site URL = this same production origin
#   Redirect URLs include https://your-domain.com/auth/confirm**
# NEXT_PUBLIC_APP_URL=https://app.sanctuaryprotected.com

# -----------------------------------------------------------------------------
# Email notifications (Resend) — server-side only
# Do NOT use NEXT_PUBLIC_ for any of these values.
# -----------------------------------------------------------------------------
# EMAIL_PROVIDER=resend
# EMAIL_PROVIDER_API_KEY=
# Optional alias also accepted by the Resend adapter:
# RESEND_API_KEY=

# Verified outbound domain (all From addresses must use this domain)
# EMAIL_DOMAIN=sanctuaryprotected.com

# Purpose-specific From addresses (controlled sender registry)
# EMAIL_FROM_ALERTS=alerts@sanctuaryprotected.com
# EMAIL_FROM_NO_REPLY=no-reply@sanctuaryprotected.com
# EMAIL_FROM_INFO=info@sanctuaryprotected.com
# EMAIL_FROM_EMERGENCY=emergency@sanctuaryprotected.com
# EMAIL_FROM_INCIDENTS=incidents@sanctuaryprotected.com
# EMAIL_FROM_ACCESS=access@sanctuaryprotected.com
# EMAIL_FROM_SUPPORT=support@sanctuaryprotected.com
# EMAIL_FROM_BILLING=billing@sanctuaryprotected.com
# EMAIL_FROM_HARDWARE=hardware@sanctuaryprotected.com

# Reply-to mailboxes (require real mailbox or forwarding outside Resend)
# EMAIL_REPLY_TO_DEFAULT=support@sanctuaryprotected.com
# EMAIL_REPLY_TO_SUPPORT=support@sanctuaryprotected.com
# EMAIL_REPLY_TO_BILLING=billing@sanctuaryprotected.com

# Temporary compatibility (deprecated): if EMAIL_FROM_ALERTS is unset, alerts may
# fall back to EMAIL_FROM_ADDRESS. Prefer the category-specific variables above.
# EMAIL_FROM_ADDRESS=alerts@sanctuaryprotected.com
# EMAIL_REPLY_TO=support@sanctuaryprotected.com

# Optional invitation reply-to override (otherwise access sender reply-to is used)
# MEMBERSHIP_INVITE_REPLY_TO=support@sanctuaryprotected.com

# Secure dispatcher + webhook verification (server-side only)
# NOTIFICATION_DISPATCH_SECRET=
# Resend webhook signing secret (whsec_...). Also accepted as NOTIFICATION_WEBHOOK_SECRET.
# RESEND_WEBHOOK_SECRET=
# NOTIFICATION_WEBHOOK_SECRET=
# Webhook URL: https://<your-app>/api/notifications/webhooks/resend
# CRON_SECRET=
# APP_BASE_URL=http://localhost:3000
#
# Local development without Resend:
# EMAIL_PROVIDER=console

# DO NOT add SUPABASE_SERVICE_ROLE_KEY to any NEXT_PUBLIC_ variable.
# The service-role key must never ship to the browser.
# Required on the server for Team → Add member AND notification email delivery rows.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
